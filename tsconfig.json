{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./*.ts",
    "./**/*.ts",
    "./*.tsx",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "jsx": "react",
    "paths": {
      "~*": [
        "./src/*"
      ],
      "@root/*": [
        "./*"
      ]
    },
    "moduleResolution": "bundler",
    "types": [
      "node",
      "chrome"
    ]
  }
}
